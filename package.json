{
  "name": "pidgn-templates",
  "displayName": "Pidgn Templates",
  "description": "Syntax highlighting for Pidgn template files (.html.pidgn)",
  "version": "0.3.0",
  "publisher": "pidgn-framework",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [
      {
        "id": "pidgn",
        "aliases": [
          "Pidgn Template",
          "pidgn"
        ],
        "extensions": [
          ".html.pidgn",
          ".pidgn"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "pidgn",
        "scopeName": "text.html.pidgn",
        "path": "./syntaxes/pidgn.tmLanguage.json",
        "embeddedLanguages": {
          "text.html.basic": "html",
          "source.js": "javascript",
          "source.css": "css"
        }
      }
    ]
  }
}
